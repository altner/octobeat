---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

interface Article {
  id: string;
  url: string;
  title: string;
  score: number;
  signal_count: number;
  curators: string[];
  platforms: string[];
  latest_shared: string;
  syndications?: Syndication[];
  engagement?: Engagement;
  tags?: string[];
}

interface Engagement {
  boosts: number;
  likes: number;
  replies: number;
  quotes: number;
}

interface Syndication {
  platform: string;
  curator: string;
  url: string;
  shared_at: string;
}

interface FeedData {
  generated_at: string;
  article_count: number;
  articles: Article[];
}

let feedData: FeedData = { generated_at: '', article_count: 0, articles: [] };
try {
  const mod = await import('../../data/feed.json');
  feedData = mod.default as FeedData;
} catch {
  // feed.json not yet generated
}

const articles = feedData.articles ?? [];
const isDev = import.meta.env.DEV;

const genTime = feedData.generated_at
  ? new Date(feedData.generated_at).toLocaleString('en-GB', {
      day: '2-digit', month: 'short', year: 'numeric',
      hour: '2-digit', minute: '2-digit',
      timeZone: 'Europe/Berlin',
      timeZoneName: 'short',
    })
  : '';

function domain(url: string) {
  try { return new URL(url).hostname.replace('www.', ''); } catch { return ''; }
}

function profileUrl(platform: string, curator: string, postUrl: string) {
  try {
    const url = new URL(postUrl);
    if (platform === 'bluesky' && url.hostname === 'bsky.app') {
      const parts = url.pathname.split('/').filter(Boolean);
      if (parts[0] === 'profile' && parts[1]) {
        return `https://bsky.app/profile/${parts[1]}`;
      }
    }
    if (platform === 'mastodon') {
      const match = url.pathname.match(/^\/@[^/]+/);
      if (match) return `${url.origin}${match[0]}`;
    }
  } catch {
    // Fall through to handle-based Bluesky fallback.
  }

  if (platform === 'bluesky' && curator) {
    return `https://bsky.app/profile/${curator}`;
  }
  return '';
}

function engagementLabel(engagement?: Engagement) {
  if (!engagement) return '';
  const parts = [
    engagement.boosts > 0 ? `${engagement.boosts} Boosts` : '',
    engagement.likes > 0 ? `${engagement.likes} Likes` : '',
    engagement.replies > 0 ? `${engagement.replies} Replies` : '',
    engagement.quotes > 0 ? `${engagement.quotes} Quotes` : '',
  ].filter(Boolean);
  return parts.join(' · ');
}

function socialRows(article: Article) {
  if ((article.syndications ?? []).length > 0) {
    return (article.syndications ?? []).slice(0, 6).map(s => ({
      platform: s.platform,
      curator: s.curator,
      url: s.url,
      profileUrl: profileUrl(s.platform, s.curator, s.url),
    }));
  }

  if (article.platforms.length !== 1) return [];
  return article.curators.slice(0, 6).map(curator => ({
    platform: article.platforms[0],
    curator,
    url: '',
    profileUrl: profileUrl(article.platforms[0], curator, ''),
  }));
}
---

<BaseLayout title="OctoBeat – Debug">
  <Header currentPage="debug" genTime={genTime} />

  {isDev ? (
  <main>
    <p class="count-line">{articles.length} article{articles.length !== 1 ? 's' : ''}</p>

    <div class="articles" id="articleList">
      {articles.map(a => (
        <article
          class="article-card"
          data-title={a.title}
          data-url={a.url}
          data-tags={(a.tags ?? []).join(' ')}
        >
          <div class="card-left">
            <div class="card-top">
              <span class="time" data-ts={a.latest_shared}></span>
            </div>

            <div class="article-title">
              <a href={a.url} target="_blank" rel="noopener">{a.title || a.url}</a>
            </div>

            <div class="article-footer">
              <span class="article-domain">{domain(a.url)}</span>
              {engagementLabel(a.engagement) && (
                <span class="engagement">{engagementLabel(a.engagement)}</span>
              )}
            </div>

            {socialRows(a).length > 0 && (
              <div class="social-signal-list" aria-label="Social posts">
                {socialRows(a).map(s => (
                  <div class="social-signal-row">
                    {s.profileUrl ? (
                      <a
                        class="social-profile"
                        href={s.profileUrl}
                        target="_blank"
                        rel="noopener"
                        title={`${s.platform}:${s.curator}`}
                      >
                        {s.curator}
                      </a>
                    ) : (
                      <span class="social-profile" title={`${s.platform}:${s.curator}`}>{s.curator}</span>
                    )}
                    {s.url ? (
                      <a
                        class="social-url"
                        href={s.url}
                        target="_blank"
                        rel="noopener"
                      >
                        {s.url}
                      </a>
                    ) : (
                      <span class="social-url muted">No post link</span>
                    )}
                    <span class="feedback-actions">
                    <button
                      class="feedback-button"
                      type="button"
                      data-platform={s.platform}
                      data-curator={s.curator}
                      data-rating="1"
                      title="Increase curator weight"
                    >+</button>
                    <button
                      class="feedback-button"
                      type="button"
                      data-platform={s.platform}
                      data-curator={s.curator}
                      data-rating="-1"
                      title="Decrease curator weight"
                    >-</button>
                    <button
                      class="feedback-button danger"
                      type="button"
                      data-platform={s.platform}
                      data-curator={s.curator}
                      data-blocked="true"
                      title="Block curator"
                    >Block</button>
                    </span>
                  </div>
                ))}
              </div>
            )}

            {(a.tags ?? []).length > 0 && (
              <div class="article-tags">
                {(a.tags ?? []).slice(0, 5).map(t => (
                  <span class="article-tag">#{t}</span>
                ))}
              </div>
            )}
          </div>

          <div class="article-score">
            <div class="score-value">{Math.round(a.score)}</div>
            <div class="score-label">Score</div>
            <div class="signal-count">{a.signal_count} signal{a.signal_count !== 1 ? 's' : ''}</div>
          </div>
        </article>
      ))}
    </div>
  </main>
  ) : (
  <main>
    <p class="count-line">Debug is only available locally in dev mode.</p>
  </main>
  )}
</BaseLayout>

<style>
  main {
    max-width: 1180px;
    margin: 0 auto;
    padding: 24px 32px 72px;
  }

  .count-line { font-size: 12px; color: var(--muted); margin-bottom: 16px; }

  .articles { display: flex; flex-direction: column; gap: 8px; }

  .article-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 18px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 86px;
    gap: 18px;
    align-items: start;
    transition: border-color 0.2s, transform 0.1s;
  }
  .article-card:hover { border-color: var(--accent); transform: translateY(-1px); }
  .article-card[hidden] { display: none; }
  .card-left { min-width: 0; }

  .card-top {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 7px;
    flex-wrap: wrap;
  }

  .time { font-size: 12px; color: var(--muted); }

  .article-title { font-size: 15px; font-weight: 600; line-height: 1.45; margin-bottom: 6px; }
  .article-title a { color: var(--text); text-decoration: none; }
  .article-title a:hover { color: var(--accent); }

  .article-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--muted);
  }
  .engagement {
    font-size: 11px;
    color: var(--accent2);
  }

  .social-signal-list {
    border: 1px solid rgba(46,51,84,0.8);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    margin-top: 10px;
    min-width: 0;
    overflow: hidden;
  }
  .social-signal-row {
    background: rgba(34,38,58,0.55);
    display: grid;
    grid-template-columns: minmax(120px, 180px) minmax(0, 1fr) auto;
    gap: 10px;
    align-items: center;
    min-width: 0;
    padding: 7px 8px;
  }
  .social-signal-row + .social-signal-row {
    border-top: 1px solid rgba(46,51,84,0.8);
  }
  .social-profile {
    color: var(--muted);
    font-size: 11px;
    min-width: 0;
    overflow: hidden;
    text-decoration: none;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  a.social-profile:hover { color: var(--accent); }
  .social-url {
    color: var(--muted);
    font-size: 11px;
    line-height: 1.4;
    min-width: 0;
    overflow: hidden;
    text-decoration: none;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .social-url:hover { color: var(--accent); }
  .social-url.muted {
    color: rgba(136,146,176,0.55);
    font-style: italic;
  }
  .feedback-actions {
    display: flex;
    gap: 6px;
    justify-content: flex-end;
  }
  .feedback-button {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
    cursor: pointer;
    font-size: 11px;
    min-width: 26px;
    padding: 2px 6px;
  }
  .feedback-button:hover {
    border-color: var(--accent);
    color: var(--text);
  }
  .feedback-button.danger:hover {
    border-color: var(--danger);
    color: var(--danger);
  }
  .feedback-button.saved {
    border-color: var(--accent);
    color: var(--accent);
  }
  .feedback-button.failed {
    border-color: var(--danger);
    color: var(--danger);
  }

  .article-tags { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 6px; }
  .article-tag {
    font-size: 10px;
    font-weight: 600;
    color: var(--accent2);
    background: rgba(167,139,250,0.1);
    border: 1px solid rgba(167,139,250,0.2);
    padding: 1px 6px;
    border-radius: 10px;
  }

  .article-score { text-align: right; min-width: 52px; }
  .score-value {
    font-size: 18px;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .score-label  { font-size: 10px; color: var(--muted); }
  .signal-count { font-size: 11px; color: var(--muted); margin-top: 2px; }

  @media (max-width: 600px) {
    main { padding: 18px 14px 56px; }
    .article-card { grid-template-columns: 1fr; }
    .article-score { text-align: left; }
    .social-signal-row {
      grid-template-columns: 1fr;
      gap: 5px;
    }
    .feedback-actions { justify-content: flex-start; }
  }
</style>

{isDev && (
  <script>
    document.querySelectorAll<HTMLElement>('.time[data-ts]').forEach(el => {
      const ts = el.dataset.ts;
      if (!ts) return;
      const diff = (Date.now() - new Date(ts).getTime()) / 1000;
      if (diff < 3600)       el.textContent = `${Math.round(diff / 60)} min ago`;
      else if (diff < 86400) el.textContent = `${Math.round(diff / 3600)} h ago`;
      else                   el.textContent = `${Math.round(diff / 86400)} days ago`;
    });

    document.querySelectorAll<HTMLButtonElement>('.feedback-button').forEach(button => {
      button.addEventListener('click', async () => {
        const payload = {
          platform: button.dataset.platform,
          curator_handle: button.dataset.curator,
          rating: button.dataset.rating ? Number(button.dataset.rating) : undefined,
          blocked: button.dataset.blocked === 'true' ? true : button.dataset.rating ? false : undefined,
        };

        button.classList.remove('saved', 'failed');
        try {
          const response = await fetch('http://127.0.0.1:8765/feedback/curator', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (!response.ok) throw new Error('feedback failed');
          button.classList.add('saved');
        } catch {
          button.classList.add('failed');
        }
      });
    });
  </script>
)}
