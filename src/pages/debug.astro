---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

interface Article {
  id: string;
  url: string;
  title: string;
  score: number;
  signal_count: number;
  curators: string[];
  platforms: string[];
  latest_shared: string;
  tags?: string[];
}

interface FeedData {
  generated_at: string;
  article_count: number;
  articles: Article[];
}

let feedData: FeedData = { generated_at: '', article_count: 0, articles: [] };
try {
  const mod = await import('../../data/feed.json');
  feedData = mod.default as FeedData;
} catch {
  // feed.json not yet generated
}

const articles = feedData.articles ?? [];

const genTime = feedData.generated_at
  ? new Date(feedData.generated_at).toLocaleString('de-DE', {
      day: '2-digit', month: 'short', year: 'numeric',
      hour: '2-digit', minute: '2-digit',
    }) + ' UTC'
  : '';

function domain(url: string) {
  try { return new URL(url).hostname.replace('www.', ''); } catch { return ''; }
}

const PLATFORM_LABELS: Record<string, string> = {
  hackernews: 'Hacker News',
  mastodon:   'Mastodon',
  bluesky:    'Bluesky',
  rss:        'RSS',
};
---

<BaseLayout title="OctoBeat – Debug">
  <Header currentPage="debug" genTime={genTime}>
    <input class="search-box" id="searchBox" type="text" placeholder="Suchen…" autocomplete="off" />
  </Header>

  <main>
    <p class="count-line">{articles.length} Artikel</p>

    <div class="articles" id="articleList">
      {articles.map(a => (
        <article
          class="article-card"
          data-title={a.title}
          data-url={a.url}
          data-tags={(a.tags ?? []).join(' ')}
        >
          <div class="card-left">
            <div class="card-top">
              {a.platforms.length > 1 ? (
                <span class="platform-tag platform-multi">Multi-Platform</span>
              ) : a.platforms.map(p => (
                <span class={`platform-tag platform-${p}`}>{PLATFORM_LABELS[p] ?? p}</span>
              ))}
              <span class="time" data-ts={a.latest_shared}></span>
            </div>

            <div class="article-title">
              <a href={a.url} target="_blank" rel="noopener">{a.title || a.url}</a>
            </div>

            <div class="article-footer">
              <span class="article-domain">{domain(a.url)}</span>
              {a.curators.length > 0 && (
                <span class="curators">👥 {a.curators.slice(0, 4).join(', ')}</span>
              )}
            </div>

            {(a.tags ?? []).length > 0 && (
              <div class="article-tags">
                {(a.tags ?? []).slice(0, 5).map(t => (
                  <span class="article-tag">#{t}</span>
                ))}
              </div>
            )}
          </div>

          <div class="article-score">
            <div class="score-value">{Math.round(a.score)}</div>
            <div class="score-label">Score</div>
            <div class="signal-count">{a.signal_count} Signal{a.signal_count !== 1 ? 'e' : ''}</div>
          </div>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  main { max-width: 780px; margin: 0 auto; padding: 20px 24px 60px; }

  .count-line { font-size: 12px; color: var(--muted); margin-bottom: 16px; }

  .articles { display: flex; flex-direction: column; gap: 8px; }

  .article-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    transition: border-color 0.2s, transform 0.1s;
  }
  .article-card:hover { border-color: var(--accent); transform: translateY(-1px); }
  .article-card[hidden] { display: none; }

  .card-top {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 7px;
    flex-wrap: wrap;
  }

  .platform-tag {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 7px;
    border-radius: 4px;
  }
  .platform-hackernews { background: rgba(255,102,0,0.15);   color: var(--hn); }
  .platform-mastodon   { background: rgba(99,100,255,0.15);  color: var(--mastodon); }
  .platform-bluesky    { background: rgba(2,133,255,0.15);   color: var(--bluesky); }
  .platform-rss        { background: rgba(246,166,35,0.15);  color: var(--rss); }
  .platform-multi      { background: rgba(167,139,250,0.15); color: var(--accent2); }

  .time { font-size: 12px; color: var(--muted); }

  .article-title { font-size: 15px; font-weight: 600; line-height: 1.45; margin-bottom: 6px; }
  .article-title a { color: var(--text); text-decoration: none; }
  .article-title a:hover { color: var(--accent); }

  .article-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--muted);
  }
  .curators {
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    font-size: 11px;
  }

  .article-tags { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 6px; }
  .article-tag {
    font-size: 10px;
    font-weight: 600;
    color: var(--accent2);
    background: rgba(167,139,250,0.1);
    border: 1px solid rgba(167,139,250,0.2);
    padding: 1px 6px;
    border-radius: 10px;
  }

  .article-score { text-align: right; min-width: 52px; }
  .score-value {
    font-size: 18px;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .score-label  { font-size: 10px; color: var(--muted); }
  .signal-count { font-size: 11px; color: var(--muted); margin-top: 2px; }

  @media (max-width: 600px) {
    .article-card { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Relative timestamps
  document.querySelectorAll<HTMLElement>('.time[data-ts]').forEach(el => {
    const ts = el.dataset.ts;
    if (!ts) return;
    const diff = (Date.now() - new Date(ts).getTime()) / 1000;
    if (diff < 3600)       el.textContent = `vor ${Math.round(diff / 60)} Min`;
    else if (diff < 86400) el.textContent = `vor ${Math.round(diff / 3600)} Std`;
    else                   el.textContent = `vor ${Math.round(diff / 86400)} Tagen`;
  });

  // Search
  const searchBox  = document.getElementById('searchBox') as HTMLInputElement;
  const allCards   = Array.from(document.querySelectorAll<HTMLElement>('.article-card'));
  const countLine  = document.querySelector<HTMLElement>('.count-line')!;
  const total      = allCards.length;

  searchBox?.addEventListener('input', () => {
    const q = searchBox.value.trim().toLowerCase();
    let visible = 0;

    allCards.forEach(card => {
      const match = !q
        || (card.dataset.title ?? '').toLowerCase().includes(q)
        || (card.dataset.url   ?? '').toLowerCase().includes(q)
        || (card.dataset.tags  ?? '').toLowerCase().includes(q);
      card.hidden = !match;
      if (match) visible++;
    });

    countLine.textContent = q ? `${visible} Treffer` : `${total} Artikel`;
  });
</script>
