---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

interface FeedsData {
  feeds?: string[];
}

let feeds: string[] = [];
try {
  const mod = await import('../../data/feeds.json');
  const data = mod.default as FeedsData | string[];
  feeds = Array.isArray(data) ? data : (data.feeds ?? []);
} catch {
  // feeds.json not yet generated
}

function domainFromUrl(url: string) {
  try { return new URL(url).hostname.replace('www.', ''); } catch { return url; }
}

const NAMES: Record<string, string> = {
  'heise.de':             'Heise Online',
  'golem.de':             'Golem',
  'netzpolitik.org':      'Netzpolitik',
  't3n.de':               't3n',
  'basicthinking.de':     'Basic Thinking',
  'mixed.de':             'Mixed',
  'stadt-bremerhaven.de': 'Caschys Blog',
  'ifun.de':              'ifun',
  'winfuture.de':         'WinFuture',
  'kuketz-blog.de':       'Kuketz Blog',
  'mobiflip.de':          'Mobiflip',
  'nextpit.de':           'NextPit',
  'carta.info':           'Carta',
  'irights.info':         'iRights',
  'travelbook.de':        'Travelbook',
  'reisereporter.de':     'Reisereporter',
  'reisehappen.de':       'Reisehappen',
  'fernwehking.de':       'Fernwehking',
  'nomadblogger.de':      'Nomadblogger',
  'reisefreiheit.org':    'Reisefreiheit',
};

function nameFromUrl(url: string) {
  return NAMES[domainFromUrl(url)] ?? domainFromUrl(url);
}

function isTravel(url: string) {
  const d = domainFromUrl(url);
  return ['reise', 'travel', 'fernweh', 'nomad'].some(k => d.includes(k));
}
---

<BaseLayout title="OctoBeat – Settings">
  <Header currentPage="feeds" />
  <main>
    <h2>Feed-URLs <span class="count">{feeds.length} Quellen</span></h2>

    {feeds.length === 0 ? (
      <p class="empty">Noch keine Feeds — bitte <code>python crawler/main.py</code> ausführen.</p>
    ) : (
      <ul class="feed-list">
        {feeds.map(url => (
          <li class="feed-card">
            <div class="feed-icon">{isTravel(url) ? '✈️' : '📰'}</div>
            <div class="feed-info">
              <div class="feed-name">{nameFromUrl(url)}</div>
              <div class="feed-url">{url}</div>
            </div>
            <a class="feed-link" href={url} target="_blank" rel="noopener">Feed ↗</a>
          </li>
        ))}
      </ul>
    )}
  </main>
</BaseLayout>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
    padding: 32px 24px 60px;
  }

  h2 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--text);
  }

  .count {
    font-size: 13px;
    color: var(--muted);
    font-weight: 400;
    margin-left: 8px;
  }

  .empty { color: var(--muted); }
  .empty code { color: var(--accent); }

  .feed-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    list-style: none;
  }

  .feed-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: border-color 0.2s;
  }
  .feed-card:hover { border-color: var(--accent); }

  .feed-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--surface2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .feed-info { flex: 1; min-width: 0; }

  .feed-name {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .feed-url {
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .feed-link {
    color: var(--muted);
    font-size: 13px;
    text-decoration: none;
    padding: 4px 8px;
    border-radius: 6px;
    border: 1px solid var(--border);
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .feed-link:hover { border-color: var(--accent); color: var(--accent); }
</style>
