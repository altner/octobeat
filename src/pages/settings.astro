---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

interface FeedsData {
  feeds?: string[];
}

let feeds: string[] = [];
const isDev = import.meta.env.DEV;
let genTime = '';
try {
  const fd = await import('../../data/feed.json');
  const generated = (fd.default as any).generated_at;
  if (generated) genTime = new Date(generated).toLocaleString('en-GB', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
    timeZone: 'Europe/Berlin',
    timeZoneName: 'short',
  });
} catch {}
try {
  const mod = await import('../../data/feeds.json');
  const data = mod.default as FeedsData | string[];
  feeds = Array.isArray(data) ? data : (data.feeds ?? []);
} catch {
  // feeds.json not yet generated
}

function domainFromUrl(url: string) {
  try { return new URL(url).hostname.replace('www.', ''); } catch { return url; }
}

const NAMES: Record<string, string> = {
  'heise.de':             'Heise Online',
  'golem.de':             'Golem',
  'netzpolitik.org':      'Netzpolitik',
  't3n.de':               't3n',
  'basicthinking.de':     'Basic Thinking',
  'mixed.de':             'Mixed',
  'stadt-bremerhaven.de': 'Caschys Blog',
  'ifun.de':              'ifun',
  'winfuture.de':         'WinFuture',
  'kuketz-blog.de':       'Kuketz Blog',
  'mobiflip.de':          'Mobiflip',
  'nextpit.de':           'NextPit',
  'carta.info':           'Carta',
  'irights.info':         'iRights',
  'travelbook.de':        'Travelbook',
  'reisereporter.de':     'Reisereporter',
  'reisehappen.de':       'Reisehappen',
  'fernwehking.de':       'Fernwehking',
  'nomadblogger.de':      'Nomadblogger',
  'reisefreiheit.org':    'Reisefreiheit',
};

function nameFromUrl(url: string) {
  return NAMES[domainFromUrl(url)] ?? domainFromUrl(url);
}

function isTravel(url: string) {
  const d = domainFromUrl(url);
  return ['reise', 'travel', 'fernweh', 'nomad'].some(k => d.includes(k));
}
---

<BaseLayout title="OctoBeat – Settings">
  <Header currentPage="settings" genTime={genTime} />
  <main>
    {!isDev && (
      <div class="api-offline-banner">
        <span class="api-offline-icon">⚙</span>
        <div>
          <strong>API offline</strong> — feed management is only available in local dev mode.
          Ratings and changes made here will not be saved.
        </div>
      </div>
    )}

    <div class="settings-head">
      <div>
        <h2>Feed URLs <span class="count">{feeds.length} source{feeds.length !== 1 ? 's' : ''}</span></h2>
        {isDev && <span class="api-state" id="feedbackApiState">Checking feedback API...</span>}
      </div>
      <form class="add-feed-form" id="addFeedForm">
        <input
          class="feed-input"
          id="feedUrlInput"
          name="feed_url"
          type="url"
          placeholder="https://example.org/feed.xml"
          autocomplete="off"
          required
          disabled={!isDev || undefined}
          title={!isDev ? "API offline — only available in dev mode" : undefined}
        />
        <button
          class="add-feed-button"
          type="submit"
          disabled={!isDev || undefined}
          title={!isDev ? "API offline — only available in dev mode" : undefined}
        >Add</button>
      </form>
    </div>

    {feeds.length === 0 ? (
      <p class="empty">No feeds yet. Run <code>python crawler/main.py</code>.</p>
    ) : (
      <ul class="feed-list">
        {feeds.map(url => (
          <li class="feed-card">
            <div class="feed-icon">{isTravel(url) ? 'TR' : 'RSS'}</div>
            <div class="feed-info">
              <div class="feed-name">{nameFromUrl(url)}</div>
              <a class="feed-url" href={url} target="_blank" rel="noopener" title={url}>{url}</a>
              <div
                class="source-status"
                data-source-status={isDev ? url : undefined}
                title="Source learning status"
              >{isDev ? 'Not observed yet' : '—'}</div>
            </div>
            <div class="feed-actions" aria-label={`Rating for ${nameFromUrl(url)}`}>
              <span
                class="rating-state"
                data-rating-state={isDev ? url : undefined}
                title="Saved feed rating"
              >Neutral</span>
              <button
                class="feedback-button"
                type="button"
                data-feed-url={isDev ? url : undefined}
                data-rating-button="up"
                title={isDev ? "Increase feed weight" : "API offline"}
                disabled={!isDev || undefined}
              >+</button>
              <button
                class="feedback-button"
                type="button"
                data-feed-url={isDev ? url : undefined}
                data-rating-button="down"
                title={isDev ? "Decrease feed weight" : "API offline"}
                disabled={!isDev || undefined}
              >-</button>
              <button
                class="feedback-button neutral"
                type="button"
                data-feed-url={isDev ? url : undefined}
                data-rating-button="neutral"
                title={isDev ? "Reset feed rating" : "API offline"}
                disabled={!isDev || undefined}
              >Neutral</button>
              <button
                class="feedback-button danger"
                type="button"
                data-feed-url={isDev ? url : undefined}
                data-blocked="true"
                data-rating-button="block"
                title={isDev ? "Block feed" : "API offline"}
                disabled={!isDev || undefined}
              >Block</button>
              <button
                class="feedback-button delete"
                type="button"
                data-delete-feed-url={isDev ? url : undefined}
                title={isDev ? "Remove feed URL" : "API offline"}
                disabled={!isDev || undefined}
              >Delete</button>
            </div>
          </li>
        ))}
      </ul>
    )}
  </main>
</BaseLayout>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
    padding: 32px 24px 60px;
  }

  .api-offline-banner {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(160, 80, 0, 0.12);
    border: 1px solid rgba(160, 80, 0, 0.4);
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 24px;
    font-size: 13px;
    color: #c8884a;
    line-height: 1.5;
  }

  .api-offline-icon {
    font-size: 16px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .api-offline-banner strong { color: #e0a060; }

  button:disabled, input:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
  }

  .settings-head {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  h2 {
    font-size: 18px;
    font-weight: 700;
    margin: 7px 0 0;
    color: var(--text);
    white-space: nowrap;
  }

  .count {
    font-size: 13px;
    color: var(--muted);
    font-weight: 400;
    margin-left: 8px;
  }

  .api-state {
    color: var(--muted);
    display: inline-block;
    font-size: 11px;
    margin-top: 5px;
  }
  .api-state.online { color: var(--accent); }
  .api-state.offline { color: var(--danger); }

  .empty { color: var(--muted); }
  .empty code { color: var(--accent); }

  .add-feed-form {
    display: flex;
    gap: 8px;
    min-width: 0;
    width: min(430px, 100%);
  }

  .feed-input {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    flex: 1;
    font: inherit;
    font-size: 13px;
    min-width: 0;
    padding: 8px 10px;
  }
  .feed-input:focus {
    border-color: var(--accent);
    outline: none;
  }

  .add-feed-button {
    background: rgba(108,142,255,0.12);
    border: 1px solid var(--accent);
    border-radius: 8px;
    color: var(--text);
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    padding: 8px 12px;
  }
  .add-feed-button.saved {
    border-color: var(--accent);
    color: var(--accent);
  }
  .add-feed-button.failed {
    border-color: var(--danger);
    color: var(--danger);
  }

  .feed-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    list-style: none;
  }

  .feed-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: border-color 0.2s;
  }
  .feed-card:hover { border-color: var(--accent); }

  .feed-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--surface2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.04em;
    color: var(--accent);
    flex-shrink: 0;
  }

  .feed-info { flex: 1; min-width: 0; }

  .feed-name {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .feed-url {
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
    text-decoration: none;
  }
  .feed-url:hover { color: var(--accent); }

  .source-status {
    color: var(--muted);
    display: inline-block;
    font-size: 11px;
    line-height: 1.2;
    margin-top: 5px;
  }
  .source-status.healthy { color: var(--accent); }
  .source-status.learning { color: var(--muted); }
  .source-status.no-social { color: var(--accent2); }
  .source-status.prune-candidate { color: var(--danger); }

  .feed-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .rating-state {
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    font-size: 11px;
    min-width: 58px;
    padding: 3px 8px;
    text-align: center;
  }
  .rating-state.positive {
    border-color: rgba(108,142,255,0.6);
    color: var(--accent);
  }
  .rating-state.negative {
    border-color: rgba(167,139,250,0.55);
    color: var(--accent2);
  }
  .rating-state.blocked {
    border-color: rgba(255,107,107,0.65);
    color: var(--danger);
  }

  .feedback-button {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
    cursor: pointer;
    font-size: 11px;
    min-width: 28px;
    padding: 3px 7px;
  }
  .feedback-button:hover {
    border-color: var(--accent);
    color: var(--text);
  }
  .feedback-button.danger:hover {
    border-color: var(--danger);
    color: var(--danger);
  }
  .feedback-button.delete:hover {
    border-color: var(--danger);
    color: var(--danger);
  }
  .feedback-button.neutral:hover {
    border-color: var(--muted);
    color: var(--text);
  }
  .feedback-button.saved {
    border-color: var(--accent);
    color: var(--accent);
  }
  .feedback-button.active {
    border-color: var(--accent);
    color: var(--text);
    background: rgba(108,142,255,0.12);
  }
  .feedback-button.danger.active {
    border-color: var(--danger);
    color: var(--danger);
    background: rgba(255,107,107,0.08);
  }
  .feedback-button.failed {
    border-color: var(--danger);
    color: var(--danger);
  }

  @media (max-width: 620px) {
    .settings-head { flex-direction: column; }
    h2 { white-space: normal; }
    .add-feed-form { width: 100%; }
    .feed-card { align-items: flex-start; }
    .feed-actions {
      width: 100%;
      justify-content: flex-start;
      padding-left: 50px;
    }
    .feed-card { flex-wrap: wrap; }
  }
</style>

{isDev && (
  <script>
    const postJson = async (path: string, payload: Record<string, unknown>) => {
      const response = await fetch(`http://127.0.0.1:8765${path}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!response.ok) throw new Error('request failed');
      return response.json();
    };

    const apiState = document.getElementById('feedbackApiState');
    const setApiState = (online: boolean) => {
      if (!apiState) return;
      apiState.textContent = online ? 'Feedback API online' : 'Feedback API offline';
      apiState.classList.toggle('online', online);
      apiState.classList.toggle('offline', !online);
    };

    type FeedFeedback = {
      feed_url: string;
      rating: number;
      blocked: boolean;
    };

    type SourceStatus = {
      feed_url: string;
      status: 'new' | 'learning' | 'healthy' | 'no_social_signals' | 'prune_candidate';
      min_runs: number;
      min_age_days: number;
      runs_seen: number;
      age_days: number;
      rss_signal_sum: number;
      social_signal_sum: number;
      top_article_sum: number;
      prune_candidate: boolean;
    };

    const feedFeedback = new Map<string, FeedFeedback>();

    const normalizedFeedback = (feedUrl: string, rating = 0, blocked = false): FeedFeedback => ({
      feed_url: feedUrl,
      rating: Math.max(-5, Math.min(5, rating)),
      blocked,
    });

    const ratingLabel = (feedback?: FeedFeedback) => {
      if (!feedback) return 'Neutral';
      if (feedback.blocked) return 'Block';
      if (feedback.rating > 0) return `+${feedback.rating}`;
      if (feedback.rating < 0) return String(feedback.rating);
      return 'Neutral';
    };

    const applyRatingState = (feedback?: FeedFeedback) => {
      const feedUrl = feedback?.feed_url;
      if (!feedUrl) return;

      const state = document.querySelector<HTMLElement>(
        `[data-rating-state="${CSS.escape(feedUrl)}"]`
      );
      state?.classList.remove('positive', 'negative', 'blocked');
      if (state) state.textContent = ratingLabel(feedback);
      if (feedback) feedFeedback.set(feedUrl, feedback);

      document
        .querySelectorAll<HTMLButtonElement>(`[data-feed-url="${CSS.escape(feedUrl)}"]`)
        .forEach(button => button.classList.remove('active'));

      if (feedback.blocked) {
        state?.classList.add('blocked');
        document
          .querySelector<HTMLButtonElement>(
            `[data-feed-url="${CSS.escape(feedUrl)}"][data-rating-button="block"]`
          )
          ?.classList.add('active');
      } else if (feedback.rating > 0) {
        state?.classList.add('positive');
        document
          .querySelector<HTMLButtonElement>(
            `[data-feed-url="${CSS.escape(feedUrl)}"][data-rating-button="up"]`
          )
          ?.classList.add('active');
      } else if (feedback.rating < 0) {
        state?.classList.add('negative');
        document
          .querySelector<HTMLButtonElement>(
            `[data-feed-url="${CSS.escape(feedUrl)}"][data-rating-button="down"]`
          )
          ?.classList.add('active');
      } else if (feedback.rating === 0) {
        document
          .querySelector<HTMLButtonElement>(
            `[data-feed-url="${CSS.escape(feedUrl)}"][data-rating-button="neutral"]`
          )
          ?.classList.add('active');
      }
    };

    const loadRatingStates = async () => {
      try {
        const response = await fetch('http://127.0.0.1:8765/feedback/feeds');
        if (!response.ok) {
          setApiState(false);
          return;
        }
        setApiState(true);
        const payload = await response.json();
        payload.feedback?.forEach((feedback: FeedFeedback) => applyRatingState(feedback));
      } catch {
        setApiState(false);
        // Feedback server is optional; ratings just stay neutral if it is not running.
      }
    };

    const sourceStatusLabel = (source: SourceStatus) => {
      const runProgress = `${source.runs_seen}/${source.min_runs} runs`;
      const ageProgress = `${source.age_days}/${source.min_age_days} days`;
      const suffix = `${runProgress}, ${source.social_signal_sum} social`;
      if (source.status === 'new') return 'Not observed yet';
      if (source.status === 'learning') return `Learning (${suffix}, ${ageProgress})`;
      if (source.status === 'healthy') return `Healthy (${suffix})`;
      if (source.status === 'no_social_signals') return `No social signals (${suffix})`;
      return `Inactive: 0 social after ${runProgress}`;
    };

    const applySourceState = (source: SourceStatus) => {
      const state = document.querySelector<HTMLElement>(
        `[data-source-status="${CSS.escape(source.feed_url)}"]`
      );
      if (!state) return;
      state.classList.remove('healthy', 'learning', 'no-social', 'prune-candidate');
      state.textContent = sourceStatusLabel(source);
      state.title = [
        `${source.rss_signal_sum} RSS signals`,
        `${source.social_signal_sum} social signals`,
        `${source.top_article_sum} top finds`,
        `${source.age_days} days observed`,
        `Inactive threshold: ${source.min_runs} runs and ${source.min_age_days} days`,
      ].join(' · ');

      if (source.status === 'healthy') state.classList.add('healthy');
      if (source.status === 'learning' || source.status === 'new') state.classList.add('learning');
      if (source.status === 'no_social_signals') state.classList.add('no-social');
      if (source.status === 'prune_candidate') state.classList.add('prune-candidate');
    };

    const loadSourceStates = async () => {
      try {
        const response = await fetch('http://127.0.0.1:8765/sources/status');
        if (!response.ok) return;
        const payload = await response.json();
        payload.sources?.forEach((source: SourceStatus) => applySourceState(source));
      } catch {
        // Source learning is optional; this appears once the feedback API is running.
      }
    };

    loadRatingStates();
    loadSourceStates();

    document.getElementById('addFeedForm')?.addEventListener('submit', async event => {
      event.preventDefault();
      const form = event.currentTarget as HTMLFormElement;
      const input = form.elements.namedItem('feed_url') as HTMLInputElement;
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');

      button?.classList.remove('saved', 'failed');
      try {
        await postJson('/feeds/add', { feed_url: input.value });
        button?.classList.add('saved');
        window.location.reload();
      } catch {
        button?.classList.add('failed');
      }
    });

    document.querySelectorAll<HTMLButtonElement>('.feedback-button').forEach(button => {
      button.addEventListener('click', async () => {
        if (button.dataset.deleteFeedUrl) {
          button.classList.remove('saved', 'failed');
          try {
            await postJson('/feeds/delete', { feed_url: button.dataset.deleteFeedUrl });
            button.classList.add('saved');
            window.location.reload();
          } catch {
            button.classList.add('failed');
          }
          return;
        }

        const feedUrl = button.dataset.feedUrl ?? '';
        const current = feedFeedback.get(feedUrl) ?? normalizedFeedback(feedUrl);
        const action = button.dataset.ratingButton;
        const nextRating =
          action === 'up'
            ? Math.min(5, current.rating + 1)
            : action === 'down'
              ? Math.max(-5, current.rating - 1)
              : 0;

        const payload = {
          feed_url: feedUrl,
          rating: nextRating,
          blocked: button.dataset.blocked === 'true' ? true : false,
        };

        button.classList.remove('saved', 'failed');
        try {
          const result = await postJson('/feedback/feed', payload);
          button.classList.add('saved');
          applyRatingState(result.feedback);
        } catch {
          button.classList.add('failed');
        }
      });
    });
  </script>
)}
