---
interface Props {
  currentPage: 'main' | 'settings' | 'inspector' | 'metrics';
  genTime?: string;
}
const { currentPage, genTime = '' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const isDev = import.meta.env.DEV;

const navItems = [
  { page: 'main',      label: 'Feeds',     href: base },
  { page: 'inspector', label: 'Inspector', href: `${base}inspector/` },
  { page: 'metrics',   label: 'Metrics',   href: `${base}metrics/` },
];

const isSettings = currentPage === 'settings';
---
<header>
  <a class="logo" href={base}>
    <img src={`${base}logo.png`} alt="OctoBeat" class="logo-img" />
  </a>
  {isDev && currentPage === 'inspector' && <span class="debug-badge">Debug</span>}
  {genTime && <span class="meta"><span class="meta-label">Updated:</span> {genTime}</span>}
  <div class="spacer"></div>
  <nav class="nav-links">
    {navItems.map(item => (
      <a
        class:list={['nav-link', { active: item.page === currentPage }]}
        href={item.href}
        aria-current={item.page === currentPage ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
  <slot />
  <a
      class:list={['settings-link', { active: isSettings }]}
      href={`${base}settings/`}
      aria-label="Settings"
      aria-current={isSettings ? 'page' : undefined}
      title="Settings"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 15.5A3.5 3.5 0 1 0 12 8a3.5 3.5 0 0 0 0 7.5Z" />
        <path d="M19.4 15a1.8 1.8 0 0 0 .36 2l.05.05a2.1 2.1 0 0 1-2.97 2.97l-.05-.05a1.8 1.8 0 0 0-2-.36 1.8 1.8 0 0 0-1.1 1.65V21.4a2.1 2.1 0 0 1-4.2 0v-.08a1.8 1.8 0 0 0-1.18-1.66 1.8 1.8 0 0 0-2 .36l-.05.05a2.1 2.1 0 0 1-2.97-2.97l.05-.05a1.8 1.8 0 0 0 .36-2 1.8 1.8 0 0 0-1.65-1.1H2a2.1 2.1 0 0 1 0-4.2h.08a1.8 1.8 0 0 0 1.66-1.18 1.8 1.8 0 0 0-.36-2l-.05-.05a2.1 2.1 0 0 1 2.97-2.97l.05.05a1.8 1.8 0 0 0 2 .36h.08A1.8 1.8 0 0 0 9.5 2.3V2.2a2.1 2.1 0 0 1 4.2 0v.08a1.8 1.8 0 0 0 1.1 1.65 1.8 1.8 0 0 0 2-.36l.05-.05a2.1 2.1 0 0 1 2.97 2.97l-.05.05a1.8 1.8 0 0 0-.36 2v.08a1.8 1.8 0 0 0 1.65 1.1h.08a2.1 2.1 0 0 1 0 4.2h-.08A1.8 1.8 0 0 0 19.4 15Z" />
      </svg>
    </a>
</header>

<style>
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .logo {
    text-decoration: none;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 80px;
    width: auto;
    display: block;
  }

  .debug-badge {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent2);
    background: rgba(167,139,250,0.12);
    border: 1px solid rgba(167,139,250,0.3);
    padding: 3px 8px;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .meta { font-size: 12px; color: var(--muted); flex-shrink: 0; }
  .meta-label { color: var(--muted); opacity: 0.6; margin-right: 2px; }
  .spacer { flex: 1; }

  .nav-links {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .nav-link {
    color: var(--muted);
    font-size: 13px;
    text-decoration: none;
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .nav-link:hover { color: var(--text); border-color: var(--muted); }
  .nav-link.active {
    color: var(--text);
    border-color: var(--accent);
    background: rgba(108,142,255,0.12);
  }

  .settings-link {
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .settings-link:hover {
    color: var(--text);
    border-color: var(--muted);
  }
  .settings-link.active {
    color: var(--text);
    border-color: var(--accent);
    background: rgba(108,142,255,0.12);
  }
  .settings-link svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 600px) {
    header { flex-wrap: wrap; }
    .nav-links { order: 3; flex: 1; }
    .nav-link { flex: 1; text-align: center; }
  }
</style>
