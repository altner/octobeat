---
interface Props {
  title?: string;
}
const { title = 'OctoBeat' } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0f1117;
      --surface:  #1a1d27;
      --surface2: #22263a;
      --border:   #2e3354;
      --accent:   #6c8eff;
      --accent2:  #a78bfa;
      --text:     #e2e8f0;
      --muted:    #8892b0;
      --danger:   #ff6b6b;
      --hn:       #ff6600;
      --mastodon: #6364ff;
      --bluesky:  #0285ff;
      --rss:      #f6a623;
      --radius:   10px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 15px;
      min-height: 100vh;
    }

    .search-box {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 8px 14px;
      border-radius: var(--radius);
      font-size: 14px;
      outline: none;
      width: 200px;
      transition: border-color 0.2s;
    }
    .search-box:focus { border-color: var(--accent); }
    .search-box::placeholder { color: var(--muted); }

    @media (max-width: 600px) {
      .search-box { width: 100%; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
