---
interface Props {
  title?: string;
  genTime?: string;
  pageType?: 'main' | 'feeds' | 'debug';
}

const { title = 'Feedbeat', genTime = '', pageType = 'main' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0f1117;
      --surface:  #1a1d27;
      --surface2: #22263a;
      --border:   #2e3354;
      --accent:   #6c8eff;
      --accent2:  #a78bfa;
      --text:     #e2e8f0;
      --muted:    #8892b0;
      --danger:   #ff6b6b;
      --hn:       #ff6600;
      --mastodon: #6364ff;
      --bluesky:  #0285ff;
      --rss:      #f6a623;
      --radius:   10px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 15px;
      min-height: 100vh;
    }

    header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 14px 24px;
      display: flex;
      align-items: center;
      gap: 14px;
      position: sticky;
      top: 0;
      z-index: 20;
    }

    .logo {
      font-size: 22px;
      font-weight: 800;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: -0.5px;
      text-decoration: none;
      flex-shrink: 0;
    }

    .debug-badge {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--accent2);
      background: rgba(167,139,250,0.12);
      border: 1px solid rgba(167,139,250,0.3);
      padding: 3px 8px;
      border-radius: 6px;
      flex-shrink: 0;
    }

    .meta { font-size: 12px; color: var(--muted); flex-shrink: 0; }
    .spacer { flex: 1; }

    .nav-link {
      color: var(--muted);
      font-size: 13px;
      text-decoration: none;
      padding: 6px 12px;
      border: 1px solid var(--border);
      border-radius: 8px;
      white-space: nowrap;
      transition: color 0.2s, border-color 0.2s;
    }
    .nav-link:hover { color: var(--text); border-color: var(--muted); }

    .search-box {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 8px 14px;
      border-radius: var(--radius);
      font-size: 14px;
      outline: none;
      width: 200px;
      transition: border-color 0.2s;
    }
    .search-box:focus { border-color: var(--accent); }
    .search-box::placeholder { color: var(--muted); }

    @media (max-width: 600px) {
      header { flex-wrap: wrap; }
      .search-box { width: 100%; }
    }
  </style>
</head>
<body>
  <header>
    <a class="logo" href={`${base}/`}>feedbeat</a>
    {pageType === 'debug' && <span class="debug-badge">Debug</span>}
    {genTime && <span class="meta">{genTime}</span>}
    <div class="spacer"></div>
    {pageType !== 'feeds' && <a class="nav-link" href={`${base}/feeds`}>Feeds</a>}
    {pageType === 'main'  && <a class="nav-link" href={`${base}/debug`}>Debug</a>}
    {(pageType === 'debug' || pageType === 'feeds') && (
      <a class="nav-link" href={`${base}/`}>← Zurück</a>
    )}
    <slot name="search" />
  </header>

  <slot />
</body>
</html>
