{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git: pull on folder open",
      "type": "shell",
      "command": "git",
      "args": ["pull", "--ff-only"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
